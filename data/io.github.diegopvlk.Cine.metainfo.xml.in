<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.diegopvlk.Cine</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <translation type="gettext">cine</translation>
  <launchable type="desktop-id">io.github.diegopvlk.Cine.desktop</launchable>
  <content_rating type="oars-1.1" />

  <url type="homepage">https://github.com/diegopvlk/Cine</url>
  <url type="bugtracker">https://github.com/diegopvlk/Cine/issues</url>
  <url type="vcs-browser">https://github.com/diegopvlk/Cine</url>
  <url type="donation">https://www.paypal.com/donate?hosted_button_id=DVL7H35GA66X6</url>
  <url type="translate">https://hosted.weblate.org/projects/cine/app/</url>
  <update_contact>diego.pvlk@gmail.com</update_contact>

  <developer id="io.github.diegopvlk">
    <name translate="no">Diego Povliuk</name>
  </developer>

  <name translate="no">Cine</name>
  <summary>Play your videos</summary>
  <description>
    <p>Cine combines a clean interface with a high-performance engine to deliver a seamless viewing experience.</p>
		<ul>
			<li>Simple Design: A refined, distraction-free interface</li>
      <li>MPV-Based: Leverages the robust power of MPV for great playback and format support</li>
      <li>Audio and Subtitles: Control track selection and synchronization for both</li>
      <li>Video Controls: Easily adjust brightness, contrast, zoom, aspect ratio, etc.</li>
		</ul>
  </description>

  <branding>
    <color type="primary" scheme_preference="light">#C7E7EC</color>
    <color type="primary" scheme_preference="dark">#283C54</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/diegopvlk/Cine/65cb73369e923eee2fea2878d9dc0e0d91c91160/screenshots/video.png</image>
      <caption>Video Playing</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/diegopvlk/Cine/65cb73369e923eee2fea2878d9dc0e0d91c91160/screenshots/preferences.png</image>
      <caption>Preferences</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/diegopvlk/Cine/65cb73369e923eee2fea2878d9dc0e0d91c91160/screenshots/options.png</image>
      <caption>Video Options</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/diegopvlk/Cine/65cb73369e923eee2fea2878d9dc0e0d91c91160/screenshots/window.png</image>
      <caption>Main Window</caption>
    </screenshot>
  </screenshots>

  <categories>
    <category>AudioVideo</category>
    <category>Audio</category>
    <category>Video</category>
  </categories>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <releases>
    <release version="1.2.1" date="2026-04-10">
      <description translate="no">
        <ul>
          <li>New: Added preference to save session on close</li>
          <li>New: Right click menu in playlist to open item location or remove item</li>
          <li>New: Added menu to select video chapters</li>
          <li>Fixed subtitle size not being saved</li>
          <li>Fixed mouse cursor not hiding during fullscreen in some cases</li>
          <li>Added support for scrolling with modifier keys</li>
          <li>Added more file extensions when adding subtitles</li>
          <li>Performance improvements</li>
          <li>Added Finnish translation</li>
          <li>Added Occitan translation</li>
          <li>Updated GNOME runtime to 50</li>
        </ul>
      </description>
    </release>
    <release version="1.1.1" date="2026-03-14">
      <description translate="no">
        <ul>
          <li>Added Chinese translation</li>
          <li>Added support for window-maximized=yes</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-03-05">
      <description translate="no">
        <ul>
          <li>New: Added support for URLs/streaming</li>
          <li>New: Preference for progress bar thumbnail preview</li>
          <li>New: Added crop to options menu</li>
          <li>Improved UI for RTL languages</li>
          <li>Improved high contrast support</li>
          <li>Added shortcuts to change subtitle/audio</li>
        </ul>
      </description>
    </release>
    <release version="1.0.9" date="2026-02-20">
      <description translate="no">
        <ul>
          <li>New: Volume level is now always restored at startup</li>
          <li>New: Toggle elapsed/remaining time by clicking on it</li>
          <li>New: Button/action to add folder to playlist</li>
          <li>New: Hold click to double playback speed</li>
          <li>Added icon indicators for subtitle/mute on/off</li>
          <li>Unmute when changing volume</li>
        </ul>
      </description>
    </release>
    <release version="1.0.8" date="2026-02-15">
      <description translate="no">
        <ul>
          <li>Added German translation</li>
        </ul>
      </description>
    </release>
    <release version="1.0.7" date="2026-02-14">
      <description translate="no">
        <ul>
          <li>The playlist now has custom icons for different file types + small fixes</li>
          <li>The Weblate page for translations is now available at: https://hosted.weblate.org/projects/cine/app/</li>
        </ul>
      </description>
    </release>
    <release version="1.0.6" date="2026-02-06">
      <description translate="no">
        <ul>
          <li>Added Dutch translation + small fixes</li>
        </ul>
      </description>
    </release>
    <release version="1.0.5" date="2026-02-04">
      <description translate="no">
        <ul>
          <li>Fixed NVIDIA video flickering</li>
          <li>Default drop action is now "Play". To "Add to Playlist", drop directly into Playlist view</li>
        </ul>
      </description>
    </release>
    <release version="1.0.4" date="2026-02-02">
      <description translate="no">
        <ul>
          <li>Added hue to video options</li>
          <li>Improved shortcuts categorization</li>
          <li>Added shortcuts for prev/next chapters</li>
          <li>The controls now uses custom icons for better compatibility</li>
          <li>Fixes and performance improvements</li>
          <li>Added Arabic translation</li>
          <li>Added Italian translation</li>
        </ul>
      </description>
    </release>
    <release version="1.0.3" date="2026-01-30">
      <description translate="no">
        <ul>
          <li>Added a preference for hardware decoding</li>
          <li>Improved video options</li>
          <li>Fixes and performance improvements</li>
          <li>Added French translation</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-01-26">
      <description translate="no">
        <ul>
          <li>Fixes and performance improvements</li>
          <li>Added support for opening video as audio track</li>
          <li>Added button to reset all video options</li>
          <li>Added support for selecting different video tracks</li>
          <li>Improved mouse and touchpad scrolling</li>
          <li>Added Russian translation</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-01-20">
      <description translate="no">
        <ul>
          <li>Initial Release</li>
        </ul>
      </description>
    </release>
  </releases>

</component>