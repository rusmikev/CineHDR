import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
try:
  locale.setlocale(locale.LC_ALL, '')
  locale.bindtextdomain('cine', localedir)
  locale.textdomain('cine')
except:
  print('Cannot set locale.')
try:
  gettext.bindtextdomain('cine', localedir)
  gettext.textdomain('cine')
except:
  print('Cannot load translations.')

if __name__ == '__main__':
    import gi

    from gettext import gettext as _
    from gi.repository import GLib

    # This should set the icon/name in sound settings to Cine,
    # but it doesn't work with mpv ao=pipewire
    GLib.set_prgname('cinehdr')
    GLib.set_application_name(_('CineHDR'))

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'cinehdr.gresource'))
    resource._register()

    from cinehdr import main
    sys.exit(main.main(VERSION))
